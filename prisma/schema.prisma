// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum DeskStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TimeSlot {
  MORNING
  AFTERNOON
  FULL_DAY
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String?
  role       UserRole @default(EMPLOYEE)
  department String?

  bookings     Booking[]
  roomBookings RoomBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Desk {
  id         String     @id @default(cuid())
  identifier String     @unique
  status     DeskStatus @default(AVAILABLE)
  department String?
  location   String?
  features   String[]   @default([])

  availableSlots String[] @default(["MORNING", "AFTERNOON", "FULL_DAY"])

  bookings    Booking[]
  dayStatuses DeskDayStatus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeskDayStatus {
  id     String     @id @default(cuid())
  deskId String
  date   DateTime
  status DeskStatus @default(AVAILABLE)

  desk Desk @relation(fields: [deskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([deskId, date])
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  deskId      String
  date        DateTime
  timeSlot    TimeSlot
  status      BookingStatus @default(CONFIRMED)
  notes       String?
  cancelledAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  desk Desk @relation(fields: [deskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deskId, date, timeSlot])
}

model MeetingRoom {
  id       String     @id @default(cuid())
  name     String     @unique
  capacity Int
  floor    Int
  location String?
  features String[]   @default([])
  status   DeskStatus @default(AVAILABLE)

  roomBookings RoomBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomBooking {
  id          String        @id @default(cuid())
  userId      String
  roomId      String
  date        DateTime
  timeSlot    TimeSlot
  status      BookingStatus @default(CONFIRMED)
  notes       String?
  cancelledAt DateTime?

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  room MeetingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, date, timeSlot])
}